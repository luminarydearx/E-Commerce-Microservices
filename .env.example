# E-Commerce Microservices - Environment Configuration
# Copy this file to .env and adjust values

# ===== Global =====
ENVIRONMENT=development
COMPOSE_PROJECT_NAME=ecommerce

# ===== Database (PostgreSQL) =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_MULTIPLE_DATABASES=auth_db,catalog_db,order_db,payment_db,notification_db,audit_db,review_db,wishlist_db,coupon_db,shipping_db,address_db,dispute_db,chat_db,flashsale_db,loyalty_db,fraud_db,seller_db,analytics_db

# ===== Redis =====
REDIS_PASSWORD=change_me_in_production

# ===== Kafka =====
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_AUTO_CREATE_TOPICS=true

# ===== Service URLs (internal Docker network) =====
AUTH_SERVICE_URL=http://auth-service:8001
CATALOG_SERVICE_URL=http://catalog-service:8002
ORDER_SERVICE_URL=http://order-service:8003
PAYMENT_SERVICE_URL=http://payment-service:8004
NOTIFICATION_SERVICE_URL=http://notification-service:8005
AUDIT_SERVICE_URL=http://audit-service:8006

# ===== Auth Service =====
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:change_me_in_production@postgres:5432/auth_db
AUTH_REDIS_URL=redis://redis:6379/0
AUTH_JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
AUTH_JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
AUTH_JWT_ISSUER=auth-service
AUTH_JWT_ALGORITHM=RS256
AUTH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=30
AUTH_MFA_ENABLED=true
AUTH_MFA_ISSUER=ECommerce
AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=
AUTH_SMTP_PASSWORD=
AUTH_SMTP_FROM=noreply@ecommerce.local
AUTH_ALLOWED_ORIGINS=["http://localhost:3000"]

# ===== Catalog Service =====
CATALOG_DATABASE_URL=jdbc:postgresql://postgres:5432/catalog_db
CATALOG_DATABASE_USER=postgres
CATALOG_DATABASE_PASSWORD=change_me_in_production
CATALOG_REDIS_URL=redis://redis:6379/1
CATALOG_JWT_PUBLIC_KEY_PATH=file:/app/keys/public.pem
CATALOG_JWT_ISSUER=auth-service

# ===== Order Service =====
ORDER_DATABASE_URL=postgres://postgres:change_me_in_production@postgres:5432/order_db
ORDER_REDIS_URL=redis://redis:6379/2
ORDER_INTERNAL_TOKEN=change_me_internal_secret

# ===== Payment Service =====
PAYMENT_DATABASE_URL=postgres://postgres:change_me_in_production@postgres:5432/payment_db
PAYMENT_REDIS_URL=redis://redis:6379/3
PAYMENT_INTERNAL_TOKEN=change_me_internal_secret
PAYMENT_MIDTRANS_SERVER_KEY=
PAYMENT_MIDTRANS_BASE_URL=https://api.sandbox.midtrans.com/v2
PAYMENT_XENDIT_SECRET_KEY=
PAYMENT_XENDIT_BASE_URL=https://api.xendit.co
PAYMENT_WEBHOOK_SECRET=

# ===== Notification Service =====
NOTIF_DATABASE_URL=postgresql+asyncpg://postgres:change_me_in_production@postgres:5432/notification_db
NOTIF_REDIS_URL=redis://redis:6379/4
NOTIF_SMTP_HOST=
NOTIF_SMTP_PORT=587
NOTIF_SMTP_USER=
NOTIF_SMTP_PASSWORD=
NOTIF_SMTP_FROM=noreply@ecommerce.local

# ===== Audit Service =====
AUDIT_DATABASE_URL=postgresql+asyncpg://postgres:change_me_in_production@postgres:5432/audit_db
AUDIT_REDIS_URL=redis://redis:6379/5

# ===== Observability =====
OTEL_ENDPOINT=http://otel-collector:4317
OTEL_SAMPLING=1.0
PROMETHEUS_RETENTION=30d

# ===== API Gateway =====
GATEWAY_PORT=8080
GATEWAY_JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
GATEWAY_REDIS_URL=redis://redis:6379/6
GATEWAY_RATE_LIMIT_GLOBAL_RPS=1000
GATEWAY_RATE_LIMIT_AUTH_RPS=5
GATEWAY_RATE_LIMIT_CHECKOUT_RPS=10

# ===== CORS =====
ALLOWED_ORIGINS=["http://localhost:3000"]

# ===== Grafana =====
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production
